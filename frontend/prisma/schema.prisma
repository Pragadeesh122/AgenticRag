generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  chatSessions  ChatSession[]
  projects      Project[]
  memories      UserMemory[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model UserMemory {
  id        String   @id @default(cuid())
  userId    String
  category  String   // work_context | personal_context | top_of_mind | preferences
  content   String   @db.Text
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, category])
  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Chat models (linked to auth User) ───

model ChatSession {
  id              String        @id @default(cuid())
  userId          String
  projectId       String?       // null = general chat, set = project-scoped chat
  backendSessionId String?      // Redis session ID from the Python backend
  title           String        @default("New chat")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages        ChatMessage[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
  @@index([projectId])
}

model ChatMessage {
  id            String      @id @default(cuid())
  chatSessionId String
  role          String      // "user" | "assistant"
  content       String      @db.Text
  toolCalls     Json        @default("[]") // ToolCall[] stored as JSON
  metadata      Json        @default("{}") // Client state (quiz answers, agent name, etc.)
  chatSession   ChatSession @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([chatSessionId, createdAt])
}

// ─── Project models (RAG pipeline) ───

model Project {
  id          String     @id @default(cuid())
  userId      String
  name        String
  description String?    @db.Text
  status      String     @default("active") // active | archived
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents    Document[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([userId, updatedAt(sort: Desc)])
}

model Document {
  id            String   @id @default(cuid())
  projectId     String
  filename      String
  fileType      String   // pdf, txt, md, csv, docx
  fileSize      Int
  chunkCount    Int      @default(0)
  chunkStrategy String?  // recursive, semantic, fixed
  status        String   @default("uploading") // uploading | processing | ready | failed
  errorMessage  String?  @db.Text
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@index([projectId, createdAt])
}
